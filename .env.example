# ============================================================
# Secure Remote Chat CLI — Environment Configuration
# ============================================================
# Copy to .env, fill in your values, then:
#   chown root:chatcli .env && chmod 640 .env

# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your numeric Telegram User ID (get it from @userinfobot)
ALLOWED_TELEGRAM_USER_IDS=123456789

# --- Shell ---
# Where ~ expands to when you type "cd ~" or just "cd"
# Set this to your actual home directory
HOME_DIR=/home/yourusername

# Extra directories prepended to PATH so user-installed tools are found
# (claude, npm globals, pip user installs, custom scripts, etc.)
# Run "which claude" in your terminal to find where it lives.
# Separate multiple paths with colons, e.g.: /home/you/.local/bin:/snap/bin
EXTRA_PATH=/home/yourusername/.local/bin:/snap/bin

# --- Output Format ---
# How command results are displayed in Telegram. Options:
#   terminal — user@host:cwd$ classic shell prompt  (default)
#   minimal  — raw output only, no decorations
#   standard — cwd header + output block + exit code
#   compact  — cwd and status on one line, then output
#   verbose  — hostname + cwd + command echoed + output + timing
#   styled   — 🟢/🔴 emoji status icons + bold text
#   rich     — ━━ border header with hostname, cwd, and command
OUTPUT_FORMAT=terminal

# --- Execution Engine ---
# Hard kill timeout in seconds (max 3600)
COMMAND_TIMEOUT=60

# Maximum output lines returned (last N lines kept)
MAX_OUTPUT_LINES=200

# Maximum output bytes (Telegram hard limit is 4096 bytes)
MAX_OUTPUT_BYTES=3900

# --- Shell ---
# Which shell binary to use for the persistent PTY session
DEFAULT_SHELL=/bin/bash

# Require inline-keyboard confirmation before running dangerous commands
# (rm -rf, mkfs, shutdown, reboot, dd of=/dev/sd*, etc.)
REQUIRE_CONFIRM_FOR_DANGEROUS=true

# --- Logging ---
LOG_DIR=/var/log/remote-cli
