# ============================================================
# Secure Remote Chat CLI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Permissions: chmod 600 .env && chown chatcli:chatcli .env

# --- Telegram ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Comma-separated Telegram numeric User IDs of authorized operators.
# Find your own ID by messaging @userinfobot on Telegram.
# NEVER authorize more users than absolutely necessary.
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321

# --- Execution Engine ---
# Hard kill timeout in seconds for any single command
COMMAND_TIMEOUT=10

# Maximum lines of output returned to the chat (last N lines kept)
MAX_OUTPUT_LINES=50

# Maximum bytes of output returned (Telegram message limit is ~4096 bytes)
MAX_OUTPUT_BYTES=3800

# --- Logging ---
# Must be writable by the chatcli system user only
LOG_DIR=/var/log/remote-cli
