# =============================================================================
# /etc/sudoers.d/chatcli
#
# Sudo config for the 'chatcli' service account.
# Install:
#   sudo cp scripts/sudoers_chatcli.example /etc/sudoers.d/chatcli
#   sudo chmod 440 /etc/sudoers.d/chatcli
#   sudo visudo -c    # validate before relying on it
#
# Two modes are provided below — pick ONE and comment out the other.
# =============================================================================

# =============================================================================
# MODE 1 — FULL ACCESS (personal / home server use)
#
# Gives chatcli unrestricted sudo. Lets you run chmod, chown, apt install,
# systemctl, and anything else without a prefix list.
# Appropriate when you are the only user on the machine and trust your setup.
# =============================================================================
chatcli ALL=(ALL) NOPASSWD: ALL


# =============================================================================
# MODE 2 — ALLOWLIST (shared / production server)
#
# Uncomment this block and comment out MODE 1 above if you want to restrict
# exactly which commands can be elevated. More secure but requires maintenance.
# =============================================================================

# -- Service management --
# Cmnd_Alias CHATCLI_SYSTEMCTL = \
